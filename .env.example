```env
# Application
BASEDIR=/usr/share/nginx/tvsacc/
PORT=3005

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql
DB_NAME=db_tvsacc
DB_USERNAME=root
DB_PASSWORD=your_database_password

# Authentication
TOKEN_SECRET=your_secure_token_secret

# SMTP / Email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=your_email@example.com
```
