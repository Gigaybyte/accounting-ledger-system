<%- include('../include/header.ejs') %>

    <section class="content">
        <div class="container-fluid">
            <div class="col-md-4">
                <div class="row">
                    <div class="col-md-6"><button type="button" class="btn bg-info" data-toggle="modal" data-target="#modal-viewdataimport">Check Entry Details</button></div>
                    <input type="hidden" id="vwcompanyid"></input>
                </div>
            </div>
        </div>
        <div class="row pt-3">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                     <h3 id="data_titles" class="card-title">Entry Details</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div id="entry-summary" class="mb-3 d-none">
  <div class="card shadow-sm border-0">
    <div class="card-body py-3">
      <div class="d-flex flex-wrap justify-content-between align-items-center">

        <div>
          <h5 id="data_title" class="mb-1 font-weight-bold"></h5>
          <small class="text-muted">
            Detailed view of entry batches and transactions
          </small>
        </div>

        <div class="d-flex gap-3 mt-3 mt-md-0">

          <div class="text-center px-3 border-right">
            <div class="text-muted small">Batches</div>
            <div id="total_batches" class="h4 mb-0 font-weight-bold text-primary">0</div>
          </div>

          <div class="text-center px-3">
            <div class="text-muted small">Transactions</div>
            <div id="total_transactions" class="h4 mb-0 font-weight-bold text-success">0</div>
          </div>

        </div>

      </div>
    </div>
  </div>
</div>
                        <table id="dt_importdata" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Batchid</th>
                                <th>Company</th>
                                <th>Trans Date</th>
                                <th>Description</th>
                                <th>Ledgername</th>
                                <th>Trans Type</th>
                                <th>Amount</th>
                                <th>Created Date</th>
                            </tr>
                        </thead>
                        <tfoot>
                            <tr>
                                <th>Batchid</th>
                                <th>Company</th>
                                <th>Trans Date</th>
                                <th>Description</th>
                                <th>Ledgername</th>
                                <th>Trans Type</th>
                                <th>Amount</th>
                                <th>Created Date</th>
                        </tfoot>
                        </table>
                    </div>
               
                   
                    </div>
                    <!-- /.card -->
            </div>
        </div>

        <div class="modal fade" id="modal-viewdataimport">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                <h4 class="modal-title">Please Select Entry Person and Date Range</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                </div>
                <div class="modal-body">
                    <h6 class="text-danger"><b>(*) Fields marked with an asterisk are mandatory</b></h6>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="ledger">Select Entry Person *</label>
                                        <select class="form-control select2" id="vwuserid" name="vwuserid">
                                            <% data.allusers.map((element)=>{%>
                                                <%if(element){%>
                                                <option value="<%=element.id%>"><%=element.firstname%> <%=element.lastname%> (<%=element.username%>)</option>
                                            <% }})%>
                                        </select>
                                    </div>
                                <!-- /.form-group -->
                                </div>
                                <div class="col-md-6">
                                <div class="form-group">
                                    <label for="vwledger">Select Date Range *</label>
                                        <input type="text" class="form-control dateranger" id="daterange" name="daterange">
                                </div>
                                <!-- /.form-group -->
                                </div>
                                <!-- /.col -->
                                
                            </div>
                            <!-- /.row -->
                          
                            <!-- /.row -->
                        </div>
                        <!-- /.card-body -->
                </div>
                <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary" id="btnviewimportfile">View Data</button>
                </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
        </div>



    </section>
<!-- Custom JS Scripts-->
<%- include('../include/footer.ejs') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.5/xlsx.min.js"></script>
<script src="/dist/js/pages/entrydtls.js"></script>