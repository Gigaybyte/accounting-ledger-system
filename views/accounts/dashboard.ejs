<%- include('../include/header.ejs') %>

    <section class="content">
        <div class="container-fluid">
        <div class="row">
            <div class="col-lg-3 col-6">
              <!-- small box -->
              <div class="small-box bg-info">
                <div class="inner">
                  <h3><%=data.compcnt%></h3>
  
                  <p>Total Companies</p>
                </div>
                <div class="icon">
                  <i class="fa fa-file-invoice-dollar"></i>
                </div>
                <a href="/companies/company" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
            <!-- ./col -->
            <div class="col-lg-3 col-6">
              <!-- small box -->
              <div class="small-box bg-success">
                <div class="inner">
                  <h3><%=data.realized%></h3>
                  <p>Total Number of Realized Transaction</p>
                </div>
                <div class="icon">
                  <i class="fas fa-dollar-sign"></i>
                </div>
                <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
            <!-- ./col -->
            <div class="col-lg-3 col-6">
                <!-- small box -->
                <div class="small-box bg-danger">
                  <div class="inner">
                    <h3><%=data.unrealized%></h3>
                    <p>Total Number of Unrealized Transaction</p>
                  </div>
                  <div class="icon">
                    <i class="fa fa-arrow-down"></i>
                  </div>
                  <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
                </div>
            </div>
              <!-- ./col -->
            <div class="col-lg-3 col-6">
              <!-- small box -->
              <div class="small-box bg-warning">
                <div class="inner">
                  <h3><%=data.ledgerscnt%></h3>
  
                  <p>Total Ledgers</p>
                </div>
                <div class="icon">
                  <i class="fa fa-invoice-dollar"></i>
                </div>
                <a href="/companies/ledgers" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
              </div>
            </div>
            <!-- ./col -->
          </div>
        </div>
    </section>

<%- include('../include/footer.ejs') %>
    
