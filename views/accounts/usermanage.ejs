<%- include('../include/header.ejs') %>

<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="pt-3 col-md-12">
        <div class="card card-primary card-tabs">
          <div class="card-header p-0 pt-2">
            <ul class="nav nav-tabs" id="user-management-tabs" role="tablist">
              <li class="px-3 pt-2">
                <h3 class="card-title font-weight-bold">
                  <i class="nav-icon fas fa-users-cog mr-2"></i>
                  User & Role 
                </h3>
              </li>

              <li class="nav-item">
                <a
                  class="nav-link active"
                  id="users-tab"
                  data-toggle="pill"
                  href="#users"
                  role="tab"
                  aria-controls="users"
                  aria-selected="true"
                >
                  <i class="fas fa-user-shield mr-1"></i>
                  Management
                </a>
              </li>

              <!-- <li class="nav-item">
                <a
                  class="nav-link"
                  id="roles-tab"
                  data-toggle="pill"
                  href="#roles"
                  role="tab"
                  aria-controls="roles"
                  aria-selected="false"
                >
                  <i class="fas fa-user-shield mr-1"></i>
                  Roles & Permissions
                </a>
              </li> -->
            </ul>
          </div>

          <div class="card-body">
            <div class="tab-content" id="user-management-tabContent">
              <div class="tab-pane fade show active" id="users" role="tabpanel">
                <h5 class="mb-3">Manage System Users</h5>
                <button id="openCreateUser" class="btn btn-primary">
                  <i class="fas fa-user-plus"></i> Create New User
                </button>
                <p class="text-muted pt-2">
                  Create, edit, and manage user accounts, login credentials, and
                  status.
                </p>

                <table
                  class="table table-bordered table-striped"
                  id="users-table"
                >
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Username</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                </table>
              </div>

              <div class="tab-pane fade" id="roles" role="tabpanel">
                <h5 class="mb-3">Manage Roles & Permissions</h5>
                <p class="text-muted">
                  Define user roles and control system access permissions.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="mdedtle">
          <i class="fas fa-user-edit"></i> Edit User
        </h5>
        <button type="button" class="close" data-dismiss="modal">
          &times;
        </button>
      </div>

      <div class="modal-body">
        <form id="editUserForm">
          <input type="hidden" id="editUserId" />

          <div class="row">
            <div class="col-md-6">
              <div class="form-group">
                <label>First Name</label>
                <input
                  type="text"
                  id="editFirstName"
                  name="editFirstName"
                  class="form-control"
                />
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Last Name</label>
                <input
                  type="text"
                  id="editLastName"
                  class="form-control"
                  name="editLastName"
                />
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Username</label>
                <input
                  type="text"
                  id="editUsername"
                  class="form-control"
                  name="editUsername"
                />
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>Status</label>
                <select id="editStatus" name="editStatus" class="form-control">
                  <option value="1">Active</option>
                  <option value="0">Inactive</option>
                </select>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group">
                <label>Password (Leave blank to keep same)</label>

                <div class="position-relative password-wrapper">
                  <input
                    type="password"
                    id="editPassword"
                    name="editPassword"
                    class="form-control"
                    autocomplete="new-password"
                    placeholder="Enter new password"
                  />

                  <span class="toggle-password" data-target="#editPassword">
                    <i class="fas fa-eye"></i>
                  </span>
                </div>
              </div>
            </div>
            <div class="col-md-6 d-none" id="confirmPasswordContainer">
              <div class="form-group">
                <label>Confirm Password</label>
                <div class="position-relative password-wrapper">
                  <input
                    type="password"
                    id="editConfirmPassword"
                    name="editConfirmPassword"
                    class="form-control"
                    autocomplete="off"
                    placeholder="Confirm password"
                  />
                  <span
                    class="toggle-password"
                    data-target="#editConfirmPassword"
                  >
                    <i class="fas fa-eye"></i>
                  </span>
                </div>
              </div>
            </div>

            <div class="col-md-12">
              <div class="form-group">
                <label>Roles</label>
                <select
                  id="editRoles"
                  class="form-control select2"
                  multiple="multiple"
                  data-placeholder="Select roles"
                  style="width: 100%"
                ></select>
              </div>
            </div>
          </div>
        </form>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">
          Close
        </button>
        <button type="button" class="btn btn-primary" id="updateUserBtn">
          <i class="fas fa-save"></i> Update
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="mctitle">
          <i class="fas fa-user-plus"></i> Create New User
        </h5>
        <button type="button" class="close" data-dismiss="modal">
          &times;
        </button>
      </div>

      <div class="modal-body">
        <form id="createUserForm">
          <div class="row">
            <div class="col-md-6">
              <div class="form-group">
                <label>First Name</label>
                <input
                  type="text"
                  id="createFirstName"
                  name="createFirstName"
                  class="form-control"
                  placeholder="Enter first name"
                />
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Last Name</label>
                <input
                  type="text"
                  id="createLastName"
                  name="createLastName"
                  class="form-control"
                  placeholder="Enter last name"
                />
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Username</label>
                <input
                  type="text"
                  id="createUsername"
                  name="createUsername"
                  class="form-control"
                  placeholder="Enter email/username"
                />
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Status</label>
                <select
                  id="createStatus"
                  name="createStatus"
                  class="form-control"
                >
                  <option value="1">Active</option>
                  <option value="0">Inactive</option>
                </select>
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Password</label>
                <div class="position-relative password-wrapper">
                  <input
                    type="password"
                    id="createPassword"
                    name="createPassword"
                    class="form-control"
                    placeholder="Enter password"
                  />
                  <span class="toggle-password" data-target="#createPassword">
                    <i class="fas fa-eye"></i>
                  </span>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label>Confirm Password</label>
                <div class="position-relative password-wrapper">
                  <input
                    type="password"
                    id="createConfirmPassword"
                    name="createConfirmPassword"
                    class="form-control"
                    placeholder="Confirm password"
                  />
                  <span
                    class="toggle-password"
                    data-target="#createConfirmPassword"
                  >
                    <i class="fas fa-eye"></i>
                  </span>
                </div>
              </div>
            </div>

            <div class="col-md-12">
              <div class="form-group">
                <label>Select Roles</label>
                <select
                  id="selectnewuserRoles"
                  name="selectnewuserRoles"
                  class="form-control select2"
                  multiple="multiple"
                  data-placeholder="Select roles"
                  style="width: 100%"
                ></select>
              </div>
            </div>
          </div>
        </form>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">
          Close
        </button>
        <button type="button" class="btn btn-success" id="createUserBtn">
          <i class="fas fa-plus"></i> Create User
        </button>
      </div>
    </div>
  </div>
</div>
<%- include('../include/footer.ejs') %>
<script src="/dist/js/pages/usermanage.js"></script>
